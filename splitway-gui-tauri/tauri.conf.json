{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Splitway",
  "version": "0.0.1",
  "identifier": "io.github.stslex.splitway",
  "build": {
    "frontendDist": "ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "",
    "beforeBuildCommand": "sh ui/build.sh"
  },
  "app": {
    "withGlobalTauri": true,
    "enableGTKAppId": true,
    "windows": [
      {
        "label": "main",
        "title": "Splitway",
        "width": 560,
        "height": 820,
        "minWidth": 380,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.png"]
  }
}
